<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="INFO">
    
    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} %highlight{%-5p} : %msg%n"/>
        </Console>
    </Appenders>
    
	<Loggers>
	    <!-- MyBatis SQL 로그 레벨 조정 -->
	    <Logger name="org.mybatis" level="info" additivity="false">
	        <AppenderRef ref="Console"/>
	    </Logger>
	
	    <Logger name="org.mybatis.spring" level="info" additivity="false">
	        <AppenderRef ref="Console"/>
	    </Logger>
	
	    <Logger name="org.mybatis.logging" level="info" additivity="false">
	        <AppenderRef ref="Console"/>
	    </Logger>
	
	    <Logger name="org.mybatis.logging.jdbc.BaseJdbcLogger" level="info" additivity="false">
	        <AppenderRef ref="Console"/>
	    </Logger>
	
	    <!-- 프로젝트 로그 -->
	    <Logger name="com.study.work.admin.dao" level="info" additivity="false">
	        <AppenderRef ref="Console"/>
	    </Logger>
	
	    <Logger name="com.study.work" level="info" additivity="false">
	        <AppenderRef ref="Console"/>
	    </Logger>
	
	    <!-- 최상위 로그 레벨 -->
	    <Root level="info">
	        <AppenderRef ref="Console"/>
	    </Root>
	</Loggers>

    
</Configuration>
