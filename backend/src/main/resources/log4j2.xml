<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="INFO">
    
    <!-- ========================================== -->
    <!-- Appenders 설정 -->
    <!-- ========================================== -->
    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} %highlight{%-5p} : %msg%n"/>
        </Console>
    </Appenders>
    
    <!-- ========================================== -->
    <!-- Loggers 설정 -->
    <!-- ========================================== -->
    <Loggers>

        <!-- ========================================== -->
        <!-- MyBatis 쿼리 로그 -->
        <!-- ========================================== -->
        <Logger name="org.mybatis" 
                level="debug" 
                additivity="false">
            <AppenderRef ref="Console"/>
        </Logger>

        <!-- ========================================== -->
        <!-- 프로젝트 로그 -->
        <!-- ========================================== -->
        <Logger name="com.study.work" 
                level="debug" 
                additivity="false">
            <AppenderRef ref="Console"/>
        </Logger>
        
        <!-- ========================================== -->
        <!-- Root Logger -->
        <!-- ========================================== -->
        <Root level="info">
            <AppenderRef ref="Console"/>
        </Root>
        
    </Loggers>
    
</Configuration>
